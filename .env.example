# ═══════════════════════════════════════════════════════════════════
#  Mega Discord Bot — Environment Variables
#  Copy to .env for LOCAL dev. On Railway, paste into Variables tab.
#  Variables here OVERRIDE config/config.json at runtime.
# ═══════════════════════════════════════════════════════════════════

# ── Discord Bot ──────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
BOT_OWNER_ID=
GUILD_ID=
CATEGORY_ID=
PERMISSION_ROLE_ID=

# ── MEGA Account ─────────────────────────────────────────────────────
MEGA_EMAIL=
MEGA_PASSWORD=

# ── ZIP Settings ─────────────────────────────────────────────────────
# ZIP_PASSWORD_MODE=auto-random   (or: fixed)
# ZIP_INPUT_PASSWORD=             (required if mode=fixed OR source zips are encrypted)
ZIP_PASSWORD_MODE=auto-random
ZIP_INPUT_PASSWORD=

# ── Mirror Engine ────────────────────────────────────────────────────
# Set MIRROR_ENABLED=true to activate the mirror engine on next start.
# The engine scans, processes all pending links, then stops itself.
MIRROR_ENABLED=false
MIRROR_USER_TOKEN=
MIRROR_SOURCE_PASSWORD=
# Comma-separated guild IDs to scan. Leave empty to scan ALL guilds the selfbot is in.
MIRROR_SOURCE_GUILD_IDS=
# Number of parallel download+upload workers (keep low: 1-3)
MIRROR_CONCURRENCY=2

# ── Dashboard ────────────────────────────────────────────────────────
# Railway sets PORT automatically. Only override if needed locally.
# GUI_PORT=3737
